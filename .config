# This is an empty file, please overwrite it after generating the .config file with the source code
# 树莓派5B BCM2712 核心架构
CONFIG_TARGET_bcm2712=y
CONFIG_TARGET_bcm2712_DEVICE_rpi_5=y
CONFIG_KERNEL_6_6=y

# 你指定全部插件
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-fan=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-partexp=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-syncdial=y
CONFIG_PACKAGE_luci-app-taskplan=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-app-passwall=y

# Intel BE200 WiFi6E + 蓝牙
CONFIG_PACKAGE_kmod-iwlwifi=y
CONFIG_PACKAGE_iwlwifi-be200=y
CONFIG_PACKAGE_kmod-bluetooth=y
CONFIG_PACKAGE_bluez-daemon=y
CONFIG_PACKAGE_bluez-tools=y

# USB 千兆/2.5G 网卡全驱动
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net-rtl8150=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-aqc111=y

# 文件系统 硬盘支持
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_exfat-fuse=y
CONFIG_PACKAGE_exfat-utils=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_usbutils=y

# 基础工具
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_sudo=y
CONFIG_PACKAGE_htop=y
